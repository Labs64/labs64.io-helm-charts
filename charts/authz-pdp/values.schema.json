{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "affinity": {
      "additionalProperties": false,
      "required": [],
      "title": "affinity",
      "type": "object"
    },
    "autoscaling": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "autoscaling",
      "type": "object"
    },
    "chart-libs": {
      "additionalProperties": true,
      "description": "Values passed to the chart-libs library dependency (present so the generated schema accepts the key Helm injects for the dependency)",
      "required": [],
      "title": "chart-libs",
      "type": "object"
    },
    "config": {
      "additionalProperties": false,
      "description": "Cerbos server config (rendered into a ConfigMap). Policies are served from\nthe disk store mounted from the policies/schemas ConfigMaps; schema enforcement\nrejects requests whose attributes violate the JSON schemas (fail closed).",
      "properties": {
        "auditEnabled": {
          "default": false,
          "title": "auditEnabled",
          "type": "boolean"
        },
        "schemaEnforcement": {
          "default": "reject",
          "title": "schemaEnforcement",
          "type": "string"
        }
      },
      "required": [
        "schemaEnforcement",
        "auditEnabled"
      ],
      "title": "config",
      "type": "object"
    },
    "enabled": {
      "default": true,
      "title": "enabled",
      "type": "boolean"
    },
    "env": {
      "items": {
        "required": []
      },
      "title": "env",
      "type": "array"
    },
    "envFrom": {
      "items": {
        "required": []
      },
      "title": "envFrom",
      "type": "array"
    },
    "fullnameOverride": {
      "default": "",
      "title": "fullnameOverride",
      "type": "string"
    },
    "global": {
      "description": "Global values are values that can be accessed from any chart or subchart by exactly the same name.",
      "required": [],
      "title": "global",
      "type": "object"
    },
    "image": {
      "additionalProperties": false,
      "description": "Cerbos container image (third-party; keeps its own non-root user).",
      "properties": {
        "pullPolicy": {
          "default": "IfNotPresent",
          "title": "pullPolicy",
          "type": "string"
        },
        "repository": {
          "default": "ghcr.io/cerbos/cerbos",
          "title": "repository",
          "type": "string"
        },
        "tag": {
          "default": "",
          "description": "Overrides the image tag whose default is the chart appVersion.",
          "title": "tag",
          "type": "string"
        }
      },
      "required": [
        "repository",
        "pullPolicy",
        "tag"
      ],
      "title": "image",
      "type": "object"
    },
    "imagePullSecrets": {
      "items": {
        "required": []
      },
      "title": "imagePullSecrets",
      "type": "array"
    },
    "livenessProbe": {
      "additionalProperties": false,
      "properties": {
        "httpGet": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "default": "/_cerbos/health",
              "title": "path",
              "type": "string"
            },
            "port": {
              "default": 3592,
              "title": "port",
              "type": "integer"
            }
          },
          "required": [
            "path",
            "port"
          ],
          "title": "httpGet",
          "type": "object"
        },
        "initialDelaySeconds": {
          "default": 10,
          "title": "initialDelaySeconds",
          "type": "integer"
        },
        "periodSeconds": {
          "default": 15,
          "title": "periodSeconds",
          "type": "integer"
        }
      },
      "required": [
        "httpGet",
        "initialDelaySeconds",
        "periodSeconds"
      ],
      "title": "livenessProbe",
      "type": "object"
    },
    "nameOverride": {
      "default": "",
      "title": "nameOverride",
      "type": "string"
    },
    "networkPolicy": {
      "additionalProperties": false,
      "description": "Restrict ingress to same-namespace callers (authproxy + module apps). The\nchart-libs helper allows all same-namespace pods on all ports; no egress needed.",
      "properties": {
        "enabled": {
          "default": true,
          "title": "enabled",
          "type": "boolean"
        },
        "gatewayNamespace": {
          "default": "tools",
          "title": "gatewayNamespace",
          "type": "string"
        },
        "ingressControllerLabels": {
          "additionalProperties": true,
          "description": "Ingress controller pod-selector labels; defaults to the internal Traefik standard\n(app.kubernetes.io/name: traefik) when empty",
          "required": [],
          "title": "ingressControllerLabels",
          "type": "object"
        },
        "observabilityNamespace": {
          "default": "monitoring",
          "description": "Namespace the observability/OTel collector runs in",
          "title": "observabilityNamespace",
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "gatewayNamespace",
        "observabilityNamespace"
      ],
      "title": "networkPolicy",
      "type": "object"
    },
    "nodeSelector": {
      "additionalProperties": false,
      "required": [],
      "title": "nodeSelector",
      "type": "object"
    },
    "podAnnotations": {
      "additionalProperties": false,
      "required": [],
      "title": "podAnnotations",
      "type": "object"
    },
    "podDisruptionBudget": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "default": true,
          "title": "enabled",
          "type": "boolean"
        },
        "minAvailable": {
          "default": 1,
          "title": "minAvailable",
          "type": "integer"
        }
      },
      "required": [
        "enabled",
        "minAvailable"
      ],
      "title": "podDisruptionBudget",
      "type": "object"
    },
    "podLabels": {
      "additionalProperties": false,
      "required": [],
      "title": "podLabels",
      "type": "object"
    },
    "podSecurityContext": {
      "additionalProperties": false,
      "required": [],
      "title": "podSecurityContext",
      "type": "object"
    },
    "readinessProbe": {
      "additionalProperties": false,
      "properties": {
        "httpGet": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "default": "/_cerbos/health",
              "title": "path",
              "type": "string"
            },
            "port": {
              "default": 3592,
              "title": "port",
              "type": "integer"
            }
          },
          "required": [
            "path",
            "port"
          ],
          "title": "httpGet",
          "type": "object"
        },
        "initialDelaySeconds": {
          "default": 5,
          "title": "initialDelaySeconds",
          "type": "integer"
        },
        "periodSeconds": {
          "default": 10,
          "title": "periodSeconds",
          "type": "integer"
        }
      },
      "required": [
        "httpGet",
        "initialDelaySeconds",
        "periodSeconds"
      ],
      "title": "readinessProbe",
      "type": "object"
    },
    "replicaCount": {
      "default": 2,
      "description": "Cerbos PDP replicas. On the hot path of every\nkeep at least 2 for HA.",
      "title": "replicaCount",
      "type": "integer"
    },
    "resources": {
      "additionalProperties": false,
      "properties": {
        "limits": {
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "default": "500m",
              "title": "cpu",
              "type": "string"
            },
            "memory": {
              "default": "256Mi",
              "title": "memory",
              "type": "string"
            }
          },
          "required": [
            "cpu",
            "memory"
          ],
          "title": "limits",
          "type": "object"
        },
        "requests": {
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "default": "50m",
              "title": "cpu",
              "type": "string"
            },
            "memory": {
              "default": "64Mi",
              "title": "memory",
              "type": "string"
            }
          },
          "required": [
            "cpu",
            "memory"
          ],
          "title": "requests",
          "type": "object"
        }
      },
      "required": [
        "limits",
        "requests"
      ],
      "title": "resources",
      "type": "object"
    },
    "securityContext": {
      "additionalProperties": false,
      "description": "The upstream Cerbos image already runs as a non-root user; we harden further\nwithout pinning uid/gid 1064 (that is our own images' contract, not Cerbos').",
      "properties": {
        "allowPrivilegeEscalation": {
          "default": false,
          "title": "allowPrivilegeEscalation",
          "type": "boolean"
        },
        "capabilities": {
          "additionalProperties": false,
          "properties": {
            "drop": {
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  }
                ],
                "required": []
              },
              "title": "drop",
              "type": "array"
            }
          },
          "required": [
            "drop"
          ],
          "title": "capabilities",
          "type": "object"
        },
        "readOnlyRootFilesystem": {
          "default": true,
          "title": "readOnlyRootFilesystem",
          "type": "boolean"
        },
        "runAsGroup": {
          "default": 1064,
          "title": "runAsGroup",
          "type": "integer"
        },
        "runAsNonRoot": {
          "default": true,
          "title": "runAsNonRoot",
          "type": "boolean"
        },
        "runAsUser": {
          "default": 1064,
          "title": "runAsUser",
          "type": "integer"
        },
        "seccompProfile": {
          "additionalProperties": false,
          "properties": {
            "type": {
              "default": "RuntimeDefault",
              "title": "type",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "seccompProfile",
          "type": "object"
        }
      },
      "required": [
        "allowPrivilegeEscalation",
        "capabilities",
        "runAsNonRoot",
        "runAsUser",
        "runAsGroup",
        "readOnlyRootFilesystem",
        "seccompProfile"
      ],
      "title": "securityContext",
      "type": "object"
    },
    "service": {
      "additionalProperties": false,
      "properties": {
        "grpcPort": {
          "default": 3593,
          "title": "grpcPort",
          "type": "integer"
        },
        "httpPort": {
          "default": 3592,
          "description": "HTTP API (authproxy edge client) and gRPC API (Java",
          "title": "httpPort",
          "type": "integer"
        },
        "port": {
          "default": 3592,
          "description": "Alias of httpPort: chart-libs' shared NetworkPolicy helper (monitoring\ningress rule) reads .Values.service.port, not the httpPort/grpcPort pair\nbelow. Cerbos serves Prometheus metrics on the HTTP listener.",
          "title": "port",
          "type": "integer"
        },
        "type": {
          "default": "ClusterIP",
          "title": "type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "port",
        "httpPort",
        "grpcPort"
      ],
      "title": "service",
      "type": "object"
    },
    "serviceAccount": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": false,
          "required": [],
          "title": "annotations",
          "type": "object"
        },
        "automount": {
          "default": true,
          "title": "automount",
          "type": "boolean"
        },
        "create": {
          "default": true,
          "title": "create",
          "type": "boolean"
        },
        "name": {
          "default": "",
          "title": "name",
          "type": "string"
        }
      },
      "required": [
        "create",
        "automount",
        "annotations",
        "name"
      ],
      "title": "serviceAccount",
      "type": "object"
    },
    "terminationGracePeriodSeconds": {
      "default": 30,
      "title": "terminationGracePeriodSeconds",
      "type": "integer"
    },
    "tolerations": {
      "items": {
        "required": []
      },
      "title": "tolerations",
      "type": "array"
    },
    "volumeMounts": {
      "items": {
        "required": []
      },
      "title": "volumeMounts",
      "type": "array"
    },
    "volumes": {
      "items": {
        "required": []
      },
      "title": "volumes",
      "type": "array"
    }
  },
  "required": [
    "enabled",
    "replicaCount",
    "image",
    "imagePullSecrets",
    "nameOverride",
    "fullnameOverride",
    "serviceAccount",
    "podAnnotations",
    "podLabels",
    "podSecurityContext",
    "securityContext",
    "service",
    "config",
    "resources",
    "livenessProbe",
    "readinessProbe",
    "autoscaling",
    "networkPolicy",
    "podDisruptionBudget",
    "terminationGracePeriodSeconds",
    "nodeSelector",
    "tolerations",
    "affinity",
    "volumes",
    "volumeMounts",
    "env",
    "envFrom"
  ],
  "type": "object"
}
