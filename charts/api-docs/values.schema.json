{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "affinity": {
      "additionalProperties": false,
      "required": [],
      "title": "affinity",
      "type": "object"
    },
    "autoscaling": {
      "additionalProperties": false,
      "description": "This section is for setting up autoscaling more information can be found here: https://kubernetes.io/docs/concepts/workloads/autoscaling/",
      "properties": {
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "maxReplicas": {
          "default": 3,
          "title": "maxReplicas",
          "type": "integer"
        },
        "minReplicas": {
          "default": 1,
          "title": "minReplicas",
          "type": "integer"
        },
        "targetCPUUtilizationPercentage": {
          "default": 80,
          "title": "targetCPUUtilizationPercentage",
          "type": "integer"
        }
      },
      "required": [
        "enabled",
        "minReplicas",
        "maxReplicas",
        "targetCPUUtilizationPercentage"
      ],
      "title": "autoscaling",
      "type": "object"
    },
    "chart-libs": {
      "additionalProperties": true,
      "description": "Values passed to the chart-libs library dependency (present so the generated schema accepts the key Helm injects for the dependency)",
      "required": [],
      "title": "chart-libs",
      "type": "object"
    },
    "enabled": {
      "default": true,
      "title": "enabled",
      "type": "boolean"
    },
    "env": {
      "items": {
        "required": []
      },
      "title": "env",
      "type": "array"
    },
    "externalSecrets": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "storeName": {
          "default": "local-kubernetes-store",
          "title": "storeName",
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "storeName"
      ],
      "title": "externalSecrets",
      "type": "object"
    },
    "fullnameOverride": {
      "default": "",
      "title": "fullnameOverride",
      "type": "string"
    },
    "gateway": {
      "additionalProperties": false,
      "description": "Gateway API HTTPRoute for swagger-ui (public docs aggregator; module API\nroutes are owned by the module charts). No auth — faithful to prior behavior.",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enable the swagger-ui HTTPRoute",
          "title": "enabled",
          "type": "boolean"
        },
        "parentRefs": {
          "description": "Gateway(s) this HTTPRoute attaches to",
          "items": {
            "anyOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "default": "labs64io-gateway",
                    "title": "name",
                    "type": "string"
                  },
                  "namespace": {
                    "default": "tools",
                    "title": "namespace",
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "namespace"
                ],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "parentRefs",
          "type": "array"
        },
        "routes": {
          "description": "Routes. Each: path, optional pathType (default PathPrefix), service{name,port};\nstripPrefix strips the matched prefix; redirectTo issues a 302 to a fixed path.",
          "items": {
            "required": []
          },
          "title": "routes",
          "type": "array"
        }
      },
      "required": [
        "enabled",
        "parentRefs"
      ],
      "title": "gateway",
      "type": "object"
    },
    "global": {
      "additionalProperties": true,
      "description": "Global values shared across Labs64.IO charts",
      "properties": {
        "domain": {
          "default": "localhost",
          "description": "Base domain; swagger-ui is exposed as gateway.\u003cdomain\u003e",
          "title": "domain",
          "type": "string"
        }
      },
      "required": [
        "domain"
      ],
      "title": "global",
      "type": "object"
    },
    "image": {
      "additionalProperties": false,
      "description": "This sets the container image more information can be found here: https://kubernetes.io/docs/concepts/containers/images/",
      "properties": {
        "pullPolicy": {
          "default": "IfNotPresent",
          "description": "This sets the pull policy for images.",
          "title": "pullPolicy",
          "type": "string"
        },
        "repository": {
          "default": "swaggerapi/swagger-ui",
          "title": "repository",
          "type": "string"
        },
        "tag": {
          "default": "",
          "description": "Overrides the image tag whose default is the chart appVersion.",
          "title": "tag",
          "type": "string"
        }
      },
      "required": [
        "repository",
        "pullPolicy",
        "tag"
      ],
      "title": "image",
      "type": "object"
    },
    "imagePullSecrets": {
      "description": "This is for the secrets for pulling an image from a private repository more information can be found here: https://kubernetes.io/docs/tasks/configure-pod-container/pull-image-private-registry/",
      "items": {
        "required": []
      },
      "title": "imagePullSecrets",
      "type": "array"
    },
    "livenessProbe": {
      "additionalProperties": false,
      "description": "This is to setup the liveness probes more information can be found here: https://kubernetes.io/docs/tasks/configure-pod-container/configure-liveness-readiness-startup-probes/",
      "properties": {
        "failureThreshold": {
          "default": 3,
          "title": "failureThreshold",
          "type": "integer"
        },
        "httpGet": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "default": "/",
              "title": "path",
              "type": "string"
            },
            "port": {
              "default": 8080,
              "title": "port",
              "type": "integer"
            }
          },
          "required": [
            "path",
            "port"
          ],
          "title": "httpGet",
          "type": "object"
        },
        "initialDelaySeconds": {
          "default": 30,
          "title": "initialDelaySeconds",
          "type": "integer"
        },
        "periodSeconds": {
          "default": 10,
          "title": "periodSeconds",
          "type": "integer"
        },
        "timeoutSeconds": {
          "default": 2,
          "title": "timeoutSeconds",
          "type": "integer"
        }
      },
      "required": [
        "httpGet",
        "initialDelaySeconds",
        "periodSeconds",
        "failureThreshold",
        "timeoutSeconds"
      ],
      "title": "livenessProbe",
      "type": "object"
    },
    "nameOverride": {
      "default": "",
      "description": "This is to override the chart name.",
      "title": "nameOverride",
      "type": "string"
    },
    "networkPolicy": {
      "additionalProperties": false,
      "description": "NetworkPolicy: allow ingress from Traefik and same-namespace pods only (rendered by chart-libs.networkpolicy)",
      "properties": {
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "extraIngress": {
          "description": "Additional raw ingress rules",
          "items": {
            "required": []
          },
          "title": "extraIngress",
          "type": "array"
        },
        "gatewayNamespace": {
          "default": "tools",
          "description": "Namespace where Traefik runs",
          "title": "gatewayNamespace",
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "gatewayNamespace",
        "extraIngress"
      ],
      "title": "networkPolicy",
      "type": "object"
    },
    "nodeSelector": {
      "additionalProperties": false,
      "required": [],
      "title": "nodeSelector",
      "type": "object"
    },
    "podAnnotations": {
      "additionalProperties": false,
      "description": "This is for setting Kubernetes Annotations to a Pod.\nFor more information checkout: https://kubernetes.io/docs/concepts/overview/working-with-objects/annotations/",
      "required": [],
      "title": "podAnnotations",
      "type": "object"
    },
    "podLabels": {
      "additionalProperties": false,
      "description": "This is for setting Kubernetes Labels to a Pod.\nFor more information checkout: https://kubernetes.io/docs/concepts/overview/working-with-objects/labels/",
      "required": [],
      "title": "podLabels",
      "type": "object"
    },
    "podSecurityContext": {
      "additionalProperties": false,
      "required": [],
      "title": "podSecurityContext",
      "type": "object"
    },
    "rbac": {
      "additionalProperties": false,
      "description": "RBAC configuration (create RBAC resources: Role, RoleBinding)",
      "properties": {
        "create": {
          "default": true,
          "title": "create",
          "type": "boolean"
        },
        "rules": {
          "items": {
            "anyOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "apiGroups": {
                    "items": {
                      "anyOf": [
                        {
                          "type": "string"
                        }
                      ],
                      "required": []
                    },
                    "title": "apiGroups",
                    "type": "array"
                  },
                  "resources": {
                    "items": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "string"
                        },
                        {
                          "type": "string"
                        }
                      ],
                      "required": []
                    },
                    "title": "resources",
                    "type": "array"
                  },
                  "verbs": {
                    "items": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "string"
                        },
                        {
                          "type": "string"
                        }
                      ],
                      "required": []
                    },
                    "title": "verbs",
                    "type": "array"
                  }
                },
                "required": [
                  "apiGroups",
                  "resources",
                  "verbs"
                ],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "rules",
          "type": "array"
        }
      },
      "required": [
        "create",
        "rules"
      ],
      "title": "rbac",
      "type": "object"
    },
    "readinessProbe": {
      "additionalProperties": false,
      "description": "This is to setup the readiness probes more information can be found here: https://kubernetes.io/docs/tasks/configure-pod-container/configure-liveness-readiness-startup-probes/",
      "properties": {
        "failureThreshold": {
          "default": 3,
          "title": "failureThreshold",
          "type": "integer"
        },
        "httpGet": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "default": "/",
              "title": "path",
              "type": "string"
            },
            "port": {
              "default": 8080,
              "title": "port",
              "type": "integer"
            }
          },
          "required": [
            "path",
            "port"
          ],
          "title": "httpGet",
          "type": "object"
        },
        "initialDelaySeconds": {
          "default": 10,
          "title": "initialDelaySeconds",
          "type": "integer"
        },
        "periodSeconds": {
          "default": 5,
          "title": "periodSeconds",
          "type": "integer"
        },
        "timeoutSeconds": {
          "default": 2,
          "title": "timeoutSeconds",
          "type": "integer"
        }
      },
      "required": [
        "httpGet",
        "initialDelaySeconds",
        "periodSeconds",
        "failureThreshold",
        "timeoutSeconds"
      ],
      "title": "readinessProbe",
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "description": "This will set the replicaset count more information can be found here: https://kubernetes.io/docs/concepts/workloads/controllers/replicaset/",
      "title": "replicaCount",
      "type": "integer"
    },
    "resources": {
      "additionalProperties": false,
      "properties": {
        "limits": {
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "default": "500m",
              "title": "cpu",
              "type": "string"
            },
            "memory": {
              "default": "1Gi",
              "title": "memory",
              "type": "string"
            }
          },
          "required": [
            "cpu",
            "memory"
          ],
          "title": "limits",
          "type": "object"
        },
        "requests": {
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "default": "100m",
              "title": "cpu",
              "type": "string"
            },
            "memory": {
              "default": "512Mi",
              "title": "memory",
              "type": "string"
            }
          },
          "required": [
            "cpu",
            "memory"
          ],
          "title": "requests",
          "type": "object"
        }
      },
      "required": [
        "limits",
        "requests"
      ],
      "title": "resources",
      "type": "object"
    },
    "secrets": {
      "additionalProperties": false,
      "description": "Secret data to be used as environment variables (delivered via envFrom)",
      "properties": {
        "data": {
          "additionalProperties": true,
          "required": [],
          "title": "data",
          "type": "object"
        }
      },
      "required": [],
      "title": "secrets",
      "type": "object"
    },
    "securityContext": {
      "additionalProperties": false,
      "properties": {
        "capabilities": {
          "additionalProperties": false,
          "properties": {
            "drop": {
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  }
                ],
                "required": []
              },
              "title": "drop",
              "type": "array"
            }
          },
          "required": [
            "drop"
          ],
          "title": "capabilities",
          "type": "object"
        },
        "runAsGroup": {
          "default": 1064,
          "title": "runAsGroup",
          "type": "integer"
        },
        "runAsNonRoot": {
          "default": true,
          "title": "runAsNonRoot",
          "type": "boolean"
        },
        "runAsUser": {
          "default": 1064,
          "title": "runAsUser",
          "type": "integer"
        },
        "seccompProfile": {
          "additionalProperties": false,
          "properties": {
            "type": {
              "default": "RuntimeDefault",
              "title": "type",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "seccompProfile",
          "type": "object"
        }
      },
      "required": [
        "capabilities",
        "runAsNonRoot",
        "runAsUser",
        "runAsGroup",
        "seccompProfile"
      ],
      "title": "securityContext",
      "type": "object"
    },
    "service": {
      "additionalProperties": false,
      "description": "This is for setting up a service more information can be found here: https://kubernetes.io/docs/concepts/services-networking/service/",
      "properties": {
        "port": {
          "default": 8080,
          "description": "This sets the ports more information can be found here: https://kubernetes.io/docs/concepts/services-networking/service/#field-spec-ports",
          "title": "port",
          "type": "integer"
        },
        "type": {
          "default": "ClusterIP",
          "description": "This sets the service type more information can be found here: https://kubernetes.io/docs/concepts/services-networking/service/#publishing-services-service-types",
          "title": "type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "port"
      ],
      "title": "service",
      "type": "object"
    },
    "serviceAccount": {
      "additionalProperties": false,
      "description": "This section builds out the service account more information can be found here: https://kubernetes.io/docs/concepts/security/service-accounts/",
      "properties": {
        "annotations": {
          "additionalProperties": false,
          "description": "Annotations to add to the service account",
          "required": [],
          "title": "annotations",
          "type": "object"
        },
        "automount": {
          "default": true,
          "description": "Automatically mount a ServiceAccount's API credentials?",
          "title": "automount",
          "type": "boolean"
        },
        "create": {
          "default": true,
          "description": "Specifies whether a service account should be created",
          "title": "create",
          "type": "boolean"
        },
        "name": {
          "default": "",
          "description": "The name of the service account to use.\nIf not set and create is true, a name is generated using the fullname template",
          "title": "name",
          "type": "string"
        }
      },
      "required": [
        "create",
        "automount",
        "annotations",
        "name"
      ],
      "title": "serviceAccount",
      "type": "object"
    },
    "swaggerUI": {
      "additionalProperties": false,
      "description": "Swagger UI configuration (ref: https://swagger.io/docs/open-source-tools/swagger-ui/usage/configuration/)",
      "properties": {
        "dom_id": {
          "default": "#swagger-ui",
          "description": "The ID of a DOM element inside which SwaggerUI will put its user interface.",
          "title": "dom_id",
          "type": "string"
        },
        "urls": {
          "description": "An array of API definition objects used by Topbar plugin. When used and Topbar plugin is enabled, the url parameter will not be parsed. Names and URLs must be unique among all items in this array, since they’re used as identifiers.",
          "items": {
            "required": []
          },
          "title": "urls",
          "type": "array"
        },
        "validatorUrl": {
          "default": "https://validator.swagger.io/validator",
          "description": "By default, Swagger UI attempts to validate specs against swagger.io’s online validator. You can use this parameter to set a different validator URL, for example for locally deployed validators. Setting it to either none, 127.0.0.1 or localhost will disable validation.",
          "title": "validatorUrl",
          "type": "string"
        }
      },
      "required": [
        "urls",
        "dom_id",
        "validatorUrl"
      ],
      "title": "swaggerUI",
      "type": "object"
    },
    "tolerations": {
      "items": {
        "required": []
      },
      "title": "tolerations",
      "type": "array"
    },
    "volumeMounts": {
      "description": "Additional volumeMounts on the output Deployment definition.",
      "items": {
        "required": []
      },
      "title": "volumeMounts",
      "type": "array"
    },
    "volumes": {
      "description": "Additional volumes on the output Deployment definition.",
      "items": {
        "required": []
      },
      "title": "volumes",
      "type": "array"
    }
  },
  "required": [
    "enabled",
    "externalSecrets",
    "replicaCount",
    "image",
    "imagePullSecrets",
    "secrets",
    "nameOverride",
    "fullnameOverride",
    "serviceAccount",
    "rbac",
    "podAnnotations",
    "podLabels",
    "podSecurityContext",
    "securityContext",
    "service",
    "gateway",
    "resources",
    "livenessProbe",
    "readinessProbe",
    "autoscaling",
    "volumes",
    "volumeMounts",
    "nodeSelector",
    "tolerations",
    "affinity",
    "env",
    "swaggerUI",
    "networkPolicy"
  ],
  "type": "object"
}
