{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "affinity": {
      "additionalProperties": false,
      "description": "Affinity for pod assignment\nFor more information: https://kubernetes.io/docs/concepts/scheduling-eviction/assign-pod-node/#affinity-and-anti-affinity",
      "required": [],
      "title": "affinity",
      "type": "object"
    },
    "applicationYaml": {
      "additionalProperties": false,
      "description": "Additional application properties",
      "properties": {
        "pipelines": {
          "description": "AuditFlow pipelines configuration",
          "items": {
            "required": []
          },
          "title": "pipelines",
          "type": "array"
        },
        "sink": {
          "additionalProperties": false,
          "description": "Sink configuration",
          "properties": {
            "discovery": {
              "additionalProperties": false,
              "description": "Discovery mode; \"local\" or \"kubernetes\"",
              "properties": {
                "mode": {
                  "default": "local",
                  "title": "mode",
                  "type": "string"
                }
              },
              "required": [
                "mode"
              ],
              "title": "discovery",
              "type": "object"
            },
            "local": {
              "additionalProperties": false,
              "description": "Local URL for the sink service",
              "properties": {
                "url": {
                  "default": "http://localhost:8082",
                  "title": "url",
                  "type": "string"
                }
              },
              "required": [
                "url"
              ],
              "title": "local",
              "type": "object"
            },
            "service": {
              "additionalProperties": false,
              "description": "Service name and namespace for the sink",
              "properties": {
                "name": {
                  "default": "auditflow-sink",
                  "title": "name",
                  "type": "string"
                },
                "namespace": {
                  "default": "default",
                  "title": "namespace",
                  "type": "string"
                }
              },
              "required": [
                "name",
                "namespace"
              ],
              "title": "service",
              "type": "object"
            }
          },
          "required": [
            "discovery",
            "local",
            "service"
          ],
          "title": "sink",
          "type": "object"
        },
        "spring": {
          "additionalProperties": false,
          "description": "Spring configuration",
          "properties": {
            "rabbitmq": {
              "additionalProperties": false,
              "description": "RabbitMQ connection params",
              "properties": {
                "host": {
                  "default": "{{ ternary (printf \"%s-rabbitmq\" .Release.Name) \"rabbitmq.tools.svc.cluster.local\" .Values.rabbitmq.enabled }}",
                  "description": "RabbitMQ host; resolves to the bundled subchart service when rabbitmq.enabled, else set your broker host",
                  "title": "host",
                  "type": "string"
                },
                "port": {
                  "default": 5672,
                  "description": "RabbitMQ port; default: 5672",
                  "title": "port",
                  "type": "integer"
                }
              },
              "required": [
                "host",
                "port"
              ],
              "title": "rabbitmq",
              "type": "object"
            }
          },
          "required": [
            "rabbitmq"
          ],
          "title": "spring",
          "type": "object"
        },
        "transformer": {
          "additionalProperties": false,
          "description": "Transformer configuration",
          "properties": {
            "discovery": {
              "additionalProperties": false,
              "description": "Discovery mode; \"local\" or \"kubernetes\"",
              "properties": {
                "mode": {
                  "default": "local",
                  "title": "mode",
                  "type": "string"
                }
              },
              "required": [
                "mode"
              ],
              "title": "discovery",
              "type": "object"
            },
            "local": {
              "additionalProperties": false,
              "description": "Local URL for the transformer service",
              "properties": {
                "url": {
                  "default": "http://localhost:8081",
                  "title": "url",
                  "type": "string"
                }
              },
              "required": [
                "url"
              ],
              "title": "local",
              "type": "object"
            },
            "service": {
              "additionalProperties": false,
              "description": "Service name and namespace for the transformer",
              "properties": {
                "name": {
                  "default": "auditflow-transformer",
                  "title": "name",
                  "type": "string"
                },
                "namespace": {
                  "default": "default",
                  "title": "namespace",
                  "type": "string"
                }
              },
              "required": [
                "name",
                "namespace"
              ],
              "title": "service",
              "type": "object"
            }
          },
          "required": [
            "discovery",
            "local",
            "service"
          ],
          "title": "transformer",
          "type": "object"
        }
      },
      "required": [
        "transformer",
        "sink",
        "pipelines",
        "spring"
      ],
      "title": "applicationYaml",
      "type": "object"
    },
    "autoscaling": {
      "additionalProperties": false,
      "description": "This section is for setting up autoscaling more information can be found here: https://kubernetes.io/docs/concepts/workloads/autoscaling/",
      "properties": {
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "maxReplicas": {
          "default": 3,
          "title": "maxReplicas",
          "type": "integer"
        },
        "minReplicas": {
          "default": 1,
          "title": "minReplicas",
          "type": "integer"
        },
        "targetCPUUtilizationPercentage": {
          "default": 80,
          "title": "targetCPUUtilizationPercentage",
          "type": "integer"
        }
      },
      "required": [
        "enabled",
        "minReplicas",
        "maxReplicas",
        "targetCPUUtilizationPercentage"
      ],
      "title": "autoscaling",
      "type": "object"
    },
    "chart-libs": {
      "additionalProperties": true,
      "description": "Values passed to the chart-libs library dependency (present so the generated schema accepts the key Helm injects for the dependency)",
      "required": [],
      "title": "chart-libs",
      "type": "object"
    },
    "env": {
      "description": "Environment variables to add to the container",
      "items": {
        "required": []
      },
      "title": "env",
      "type": "array"
    },
    "fullnameOverride": {
      "default": "",
      "title": "fullnameOverride",
      "type": "string"
    },
    "gateway": {
      "additionalProperties": false,
      "description": "Gateway routes published by this module (rendered by chart-libs.gateway-routes)",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Publish this module's routes on the Traefik gateway",
          "title": "enabled",
          "type": "boolean"
        },
        "entryPoints": {
          "description": "Traefik entry points",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ],
            "required": []
          },
          "title": "entryPoints",
          "type": "array"
        },
        "prefix": {
          "default": "",
          "description": "External path prefix; defaults to /\u003cchart-name\u003e",
          "title": "prefix",
          "type": "string"
        },
        "routes": {
          "description": "Routes exposed by this module",
          "items": {
            "anyOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "path": {
                    "default": "/api",
                    "title": "path",
                    "type": "string"
                  },
                  "port": {
                    "default": 8080,
                    "title": "port",
                    "type": "integer"
                  },
                  "roles": {
                    "items": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "string"
                        },
                        {
                          "type": "string"
                        }
                      ],
                      "required": []
                    },
                    "title": "roles",
                    "type": "array"
                  }
                },
                "required": [
                  "path",
                  "port",
                  "roles"
                ],
                "type": "object"
              },
              {
                "additionalProperties": false,
                "properties": {
                  "path": {
                    "default": "/v3/api-docs",
                    "title": "path",
                    "type": "string"
                  },
                  "port": {
                    "default": 8080,
                    "title": "port",
                    "type": "integer"
                  },
                  "public": {
                    "default": true,
                    "title": "public",
                    "type": "boolean"
                  },
                  "stripPrefix": {
                    "default": true,
                    "title": "stripPrefix",
                    "type": "boolean"
                  }
                },
                "required": [
                  "path",
                  "port",
                  "public",
                  "stripPrefix"
                ],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "routes",
          "type": "array"
        },
        "sharedMiddlewares": {
          "additionalProperties": false,
          "description": "Names of the shared middlewares provided by the gateway-common chart",
          "properties": {
            "auth": {
              "default": "gateway-common-auth",
              "title": "auth",
              "type": "string"
            },
            "rateLimit": {
              "default": "gateway-common-ratelimit",
              "title": "rateLimit",
              "type": "string"
            },
            "securityHeaders": {
              "default": "gateway-common-security-headers",
              "title": "securityHeaders",
              "type": "string"
            }
          },
          "required": [
            "auth",
            "rateLimit",
            "securityHeaders"
          ],
          "title": "sharedMiddlewares",
          "type": "object"
        }
      },
      "required": [
        "enabled",
        "prefix",
        "entryPoints",
        "sharedMiddlewares",
        "routes"
      ],
      "title": "gateway",
      "type": "object"
    },
    "global": {
      "additionalProperties": true,
      "description": "Global values shared across Labs64.IO charts and Bitnami subcharts",
      "properties": {
        "security": {
          "additionalProperties": false,
          "properties": {
            "allowInsecureImages": {
              "default": true,
              "description": "Required by Bitnami subcharts when images are pulled from bitnamilegacy (image substitution guard)",
              "title": "allowInsecureImages",
              "type": "boolean"
            }
          },
          "required": [
            "allowInsecureImages"
          ],
          "title": "security",
          "type": "object"
        }
      },
      "required": [
        "security"
      ],
      "title": "global",
      "type": "object"
    },
    "image": {
      "additionalProperties": false,
      "description": "This sets the container image more information can be found here: https://kubernetes.io/docs/concepts/containers/images/",
      "properties": {
        "pullPolicy": {
          "default": "IfNotPresent",
          "description": "This sets the pull policy for images.",
          "title": "pullPolicy",
          "type": "string"
        },
        "repository": {
          "default": "labs64/auditflow",
          "title": "repository",
          "type": "string"
        },
        "tag": {
          "default": "",
          "description": "Overrides the image tag whose default is the chart appVersion.",
          "title": "tag",
          "type": "string"
        }
      },
      "required": [
        "repository",
        "pullPolicy",
        "tag"
      ],
      "title": "image",
      "type": "object"
    },
    "imagePullSecrets": {
      "description": "This is for the secrets for pulling an image from a private repository more information can be found here: https://kubernetes.io/docs/tasks/configure-pod-container/pull-image-private-registry/",
      "items": {
        "required": []
      },
      "title": "imagePullSecrets",
      "type": "array"
    },
    "ingress": {
      "additionalProperties": false,
      "description": "This block is for setting up the ingress for more information can be found here: https://kubernetes.io/docs/concepts/services-networking/ingress/",
      "properties": {
        "annotations": {
          "additionalProperties": false,
          "required": [],
          "title": "annotations",
          "type": "object"
        },
        "className": {
          "default": "",
          "title": "className",
          "type": "string"
        },
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "hosts": {
          "description": "kubernetes.io/ingress.class: nginx\nkubernetes.io/tls-acme: \"true\"",
          "items": {
            "anyOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "host": {
                    "default": "chart-example.local",
                    "title": "host",
                    "type": "string"
                  },
                  "paths": {
                    "items": {
                      "anyOf": [
                        {
                          "additionalProperties": false,
                          "properties": {
                            "path": {
                              "default": "/",
                              "title": "path",
                              "type": "string"
                            },
                            "pathType": {
                              "default": "ImplementationSpecific",
                              "title": "pathType",
                              "type": "string"
                            }
                          },
                          "required": [
                            "path",
                            "pathType"
                          ],
                          "type": "object"
                        }
                      ],
                      "required": []
                    },
                    "title": "paths",
                    "type": "array"
                  }
                },
                "required": [
                  "host",
                  "paths"
                ],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "hosts",
          "type": "array"
        },
        "tls": {
          "items": {
            "required": []
          },
          "title": "tls",
          "type": "array"
        }
      },
      "required": [
        "enabled",
        "className",
        "annotations",
        "hosts",
        "tls"
      ],
      "title": "ingress",
      "type": "object"
    },
    "ingressroute": {
      "additionalProperties": false,
      "description": "IngressRoute configuration for Traefik more information can be found here: https://doc.traefik.io/traefik/routing/providers/kubernetes-crd/",
      "properties": {
        "enabled": {
          "default": false,
          "description": "This sets whether the IngressRoute is enabled or not",
          "title": "enabled",
          "type": "boolean"
        },
        "entryPoints": {
          "description": "Entry points for the IngressRoute",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ],
            "required": []
          },
          "title": "entryPoints",
          "type": "array"
        },
        "host": {
          "default": "localhost",
          "description": "Host for the IngressRoute",
          "title": "host",
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "host",
        "entryPoints"
      ],
      "title": "ingressroute",
      "type": "object"
    },
    "livenessProbe": {
      "additionalProperties": false,
      "description": "This is to setup the liveness probes more information can be found here: https://kubernetes.io/docs/tasks/configure-pod-container/configure-liveness-readiness-startup-probes/",
      "properties": {
        "failureThreshold": {
          "default": 3,
          "title": "failureThreshold",
          "type": "integer"
        },
        "httpGet": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "default": "/actuator/health/liveness",
              "title": "path",
              "type": "string"
            },
            "port": {
              "default": 8080,
              "title": "port",
              "type": "integer"
            }
          },
          "required": [
            "path",
            "port"
          ],
          "title": "httpGet",
          "type": "object"
        },
        "initialDelaySeconds": {
          "default": 30,
          "title": "initialDelaySeconds",
          "type": "integer"
        },
        "periodSeconds": {
          "default": 10,
          "title": "periodSeconds",
          "type": "integer"
        },
        "timeoutSeconds": {
          "default": 2,
          "title": "timeoutSeconds",
          "type": "integer"
        }
      },
      "required": [
        "httpGet",
        "initialDelaySeconds",
        "periodSeconds",
        "failureThreshold",
        "timeoutSeconds"
      ],
      "title": "livenessProbe",
      "type": "object"
    },
    "nameOverride": {
      "default": "",
      "description": "This is to override the chart name.",
      "title": "nameOverride",
      "type": "string"
    },
    "networkPolicy": {
      "additionalProperties": false,
      "description": "NetworkPolicy: allow ingress from Traefik and same-namespace pods only (rendered by chart-libs.networkpolicy)",
      "properties": {
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "extraIngress": {
          "description": "Additional raw ingress rules",
          "items": {
            "required": []
          },
          "title": "extraIngress",
          "type": "array"
        },
        "gatewayNamespace": {
          "default": "tools",
          "description": "Namespace where Traefik runs",
          "title": "gatewayNamespace",
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "gatewayNamespace",
        "extraIngress"
      ],
      "title": "networkPolicy",
      "type": "object"
    },
    "nodeSelector": {
      "additionalProperties": false,
      "description": "Node labels for pod assignment\nFor more information: https://kubernetes.io/docs/concepts/scheduling-eviction/assign-pod-node/",
      "required": [],
      "title": "nodeSelector",
      "type": "object"
    },
    "podAnnotations": {
      "additionalProperties": false,
      "description": "This is for setting Kubernetes Annotations to a Pod.\nFor more information checkout: https://kubernetes.io/docs/concepts/overview/working-with-objects/annotations/",
      "required": [],
      "title": "podAnnotations",
      "type": "object"
    },
    "podDisruptionBudget": {
      "additionalProperties": false,
      "description": "PodDisruptionBudget (rendered by chart-libs.pdb)",
      "properties": {
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "minAvailable": {
          "default": 1,
          "title": "minAvailable",
          "type": "integer"
        }
      },
      "required": [
        "enabled",
        "minAvailable"
      ],
      "title": "podDisruptionBudget",
      "type": "object"
    },
    "podLabels": {
      "additionalProperties": false,
      "description": "This is for setting Kubernetes Labels to a Pod.\nFor more information checkout: https://kubernetes.io/docs/concepts/overview/working-with-objects/labels/",
      "required": [],
      "title": "podLabels",
      "type": "object"
    },
    "podSecurityContext": {
      "additionalProperties": false,
      "properties": {
        "fsGroup": {
          "default": 1064,
          "title": "fsGroup",
          "type": "integer"
        },
        "runAsGroup": {
          "default": 1064,
          "title": "runAsGroup",
          "type": "integer"
        },
        "runAsNonRoot": {
          "default": true,
          "title": "runAsNonRoot",
          "type": "boolean"
        },
        "runAsUser": {
          "default": 1064,
          "title": "runAsUser",
          "type": "integer"
        },
        "seccompProfile": {
          "additionalProperties": false,
          "properties": {
            "type": {
              "default": "RuntimeDefault",
              "title": "type",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "seccompProfile",
          "type": "object"
        }
      },
      "required": [
        "runAsNonRoot",
        "runAsUser",
        "runAsGroup",
        "fsGroup",
        "seccompProfile"
      ],
      "title": "podSecurityContext",
      "type": "object"
    },
    "rabbitmq": {
      "additionalProperties": true,
      "description": "Optional bundled RabbitMQ (Bitnami subchart) for standalone/local installs.\nDev-grade credentials - NOT for production; point applicationYaml at your own broker instead.",
      "properties": {
        "auth": {
          "additionalProperties": true,
          "properties": {
            "password": {
              "default": "labs64-local",
              "title": "password",
              "type": "string"
            },
            "username": {
              "default": "labs64",
              "title": "username",
              "type": "string"
            }
          },
          "required": [
            "username",
            "password"
          ],
          "title": "auth",
          "type": "object"
        },
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "image": {
          "additionalProperties": true,
          "description": "docker.io/bitnami versioned tags were moved to bitnamilegacy; keep in sync with the subchart's default tag",
          "properties": {
            "repository": {
              "default": "bitnamilegacy/rabbitmq",
              "title": "repository",
              "type": "string"
            }
          },
          "required": [
            "repository"
          ],
          "title": "image",
          "type": "object"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "rabbitmq",
      "type": "object"
    },
    "rbac": {
      "additionalProperties": false,
      "description": "RBAC configuration (create RBAC resources: Role, RoleBinding)",
      "properties": {
        "create": {
          "default": false,
          "title": "create",
          "type": "boolean"
        },
        "rules": {
          "items": {
            "required": []
          },
          "title": "rules",
          "type": "array"
        }
      },
      "required": [
        "create",
        "rules"
      ],
      "title": "rbac",
      "type": "object"
    },
    "readinessProbe": {
      "additionalProperties": false,
      "description": "This is to setup the readiness probes more information can be found here: https://kubernetes.io/docs/tasks/configure-pod-container/configure-liveness-readiness-startup-probes/",
      "properties": {
        "failureThreshold": {
          "default": 3,
          "title": "failureThreshold",
          "type": "integer"
        },
        "httpGet": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "default": "/actuator/health/readiness",
              "title": "path",
              "type": "string"
            },
            "port": {
              "default": 8080,
              "title": "port",
              "type": "integer"
            }
          },
          "required": [
            "path",
            "port"
          ],
          "title": "httpGet",
          "type": "object"
        },
        "initialDelaySeconds": {
          "default": 10,
          "title": "initialDelaySeconds",
          "type": "integer"
        },
        "periodSeconds": {
          "default": 5,
          "title": "periodSeconds",
          "type": "integer"
        },
        "timeoutSeconds": {
          "default": 2,
          "title": "timeoutSeconds",
          "type": "integer"
        }
      },
      "required": [
        "httpGet",
        "initialDelaySeconds",
        "periodSeconds",
        "failureThreshold",
        "timeoutSeconds"
      ],
      "title": "readinessProbe",
      "type": "object"
    },
    "replicaCount": {
      "default": 1,
      "description": "This will set the replicaset count more information can be found here: https://kubernetes.io/docs/concepts/workloads/controllers/replicaset/",
      "title": "replicaCount",
      "type": "integer"
    },
    "resources": {
      "additionalProperties": false,
      "description": "Resource limits and requests for the container\nFor production, it's recommended to set both requests and limits",
      "properties": {
        "limits": {
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "default": "500m",
              "title": "cpu",
              "type": "string"
            },
            "memory": {
              "default": "1Gi",
              "title": "memory",
              "type": "string"
            }
          },
          "required": [
            "cpu",
            "memory"
          ],
          "title": "limits",
          "type": "object"
        },
        "requests": {
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "default": "100m",
              "title": "cpu",
              "type": "string"
            },
            "memory": {
              "default": "512Mi",
              "title": "memory",
              "type": "string"
            }
          },
          "required": [
            "cpu",
            "memory"
          ],
          "title": "requests",
          "type": "object"
        }
      },
      "required": [
        "limits",
        "requests"
      ],
      "title": "resources",
