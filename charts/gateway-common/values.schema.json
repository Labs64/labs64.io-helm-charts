{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "authProxy": {
      "additionalProperties": false,
      "description": "ForwardAuth middleware configuration (OIDC/JWT validation via traefik-authproxy)",
      "properties": {
        "address": {
          "default": "",
          "description": "Full URL override for the traefik-authproxy /auth endpoint; when empty the address is derived as http://\u003cserviceName\u003e.\u003crelease-namespace\u003e.svc.cluster.local:\u003cport\u003e/auth",
          "title": "address",
          "type": "string"
        },
        "authResponseHeaders": {
          "description": "Identity headers copied from the authproxy response onto the upstream request (the authproxy emits every one on each 2xx, so client values can never pass through)",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "string"
              },
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ],
            "required": []
          },
          "title": "authResponseHeaders",
          "type": "array"
        },
        "port": {
          "default": 8081,
          "description": "Service port of the traefik-authproxy release",
          "title": "port",
          "type": "integer"
        },
        "serviceName": {
          "default": "labs64io-traefik-authproxy",
          "description": "Service name of the traefik-authproxy release",
          "title": "serviceName",
          "type": "string"
        },
        "trustForwardHeader": {
          "default": true,
          "description": "Trust X-Forwarded-* headers from the proxy",
          "title": "trustForwardHeader",
          "type": "boolean"
        }
      },
      "required": [
        "address",
        "serviceName",
        "port",
        "trustForwardHeader",
        "authResponseHeaders"
      ],
      "title": "authProxy",
      "type": "object"
    },
    "chart-libs": {
      "additionalProperties": true,
      "description": "Values passed to the chart-libs library dependency (present so the generated schema accepts the key Helm injects for the dependency)",
      "required": [],
      "title": "chart-libs",
      "type": "object"
    },
    "compress": {
      "additionalProperties": false,
      "description": "Response-compression middleware (edge optimization for all modules routed through Traefik)",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enable the shared compress middleware",
          "title": "enabled",
          "type": "boolean"
        },
        "excludedContentTypes": {
          "description": "Content types excluded from compression (already-compressed formats)",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "string"
              },
              {
                "type": "string"
              },
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ],
            "required": []
          },
          "title": "excludedContentTypes",
          "type": "array"
        },
        "minResponseBodyBytes": {
          "default": 1024,
          "description": "Do not compress responses below this size (bytes)",
          "title": "minResponseBodyBytes",
          "type": "integer"
        }
      },
      "required": [
        "enabled",
        "minResponseBodyBytes",
        "excludedContentTypes"
      ],
      "title": "compress",
      "type": "object"
    },
    "fullnameOverride": {
      "default": "gateway-common",
      "description": "Fixed resource-name prefix so module charts can reference middlewares by a stable name",
      "title": "fullnameOverride",
      "type": "string"
    },
    "global": {
      "description": "Global values are values that can be accessed from any chart or subchart by exactly the same name.",
      "required": [],
      "title": "global",
      "type": "object"
    },
    "nameOverride": {
      "default": "",
      "description": "This is to override the chart name.",
      "title": "nameOverride",
      "type": "string"
    },
    "rateLimit": {
      "additionalProperties": false,
      "description": "Rate limit middleware configuration",
      "properties": {
        "average": {
          "default": 100,
          "description": "Average requests per second",
          "title": "average",
          "type": "integer"
        },
        "burst": {
          "default": 50,
          "description": "Burst size",
          "title": "burst",
          "type": "integer"
        },
        "perUser": {
          "default": true,
          "description": "Rate-limit per authenticated user (X-Auth-User header set by the auth middleware); falls back to per-IP when absent",
          "title": "perUser",
          "type": "boolean"
        }
      },
      "required": [
        "average",
        "burst",
        "perUser"
      ],
      "title": "rateLimit",
      "type": "object"
    },
    "securityHeaders": {
      "additionalProperties": false,
      "description": "Security headers middleware configuration",
      "properties": {
        "browserXssFilter": {
          "default": true,
          "title": "browserXssFilter",
          "type": "boolean"
        },
        "contentSecurityPolicy": {
          "default": "default-src 'self'; script-src 'self'; object-src 'none'",
          "title": "contentSecurityPolicy",
          "type": "string"
        },
        "contentTypeNosniff": {
          "default": true,
          "title": "contentTypeNosniff",
          "type": "boolean"
        },
        "forceSTSHeader": {
          "default": true,
          "title": "forceSTSHeader",
          "type": "boolean"
        },
        "frameDeny": {
          "default": true,
          "title": "frameDeny",
          "type": "boolean"
        },
        "referrerPolicy": {
          "default": "strict-origin-when-cross-origin",
          "title": "referrerPolicy",
          "type": "string"
        },
        "stsIncludeSubdomains": {
          "default": true,
          "title": "stsIncludeSubdomains",
          "type": "boolean"
        },
        "stsSeconds": {
          "default": 31536000,
          "title": "stsSeconds",
          "type": "integer"
        }
      },
      "required": [
        "frameDeny",
        "contentTypeNosniff",
        "browserXssFilter",
        "referrerPolicy",
        "contentSecurityPolicy",
        "forceSTSHeader",
        "stsSeconds",
        "stsIncludeSubdomains"
      ],
      "title": "securityHeaders",
      "type": "object"
    }
  },
  "required": [
    "fullnameOverride",
    "nameOverride",
    "authProxy",
    "rateLimit",
    "compress",
    "securityHeaders"
  ],
  "type": "object"
}
