    "payment-gateway": {
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "default": true,
          "title": "enabled",
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "payment-gateway",
      "type": "object"
    },
    "postgresql": {
      "additionalProperties": true,
      "description": "Opt-In Infrastructure (Enabled by default for one-click dev deployments)",
      "properties": {
        "auth": {
          "additionalProperties": true,
          "properties": {
            "database": {
              "default": "labs64io",
              "title": "database",
              "type": "string"
            },
            "existingSecret": {
              "default": "labs64io-shared-secret",
              "title": "existingSecret",
              "type": "string"
            },
            "secretKeys": {
              "additionalProperties": true,
              "properties": {
                "adminPasswordKey": {
                  "default": "SPRING_DATASOURCE_PASSWORD",
                  "title": "adminPasswordKey",
                  "type": "string"
                },
                "userPasswordKey": {
                  "default": "SPRING_DATASOURCE_PASSWORD",
                  "title": "userPasswordKey",
                  "type": "string"
                }
              },
              "required": [
                "adminPasswordKey",
                "userPasswordKey"
              ],
              "title": "secretKeys",
              "type": "object"
            },
            "username": {
              "default": "labs64",
              "title": "username",
              "type": "string"
            }
          },
          "required": [
            "username",
            "database",
            "existingSecret"
          ],
          "title": "auth",
          "type": "object"
        },
        "enabled": {
          "default": true,
          "title": "enabled",
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "postgresql",
      "type": "object"
