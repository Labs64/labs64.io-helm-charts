      "additionalProperties": true,
      "properties": {
        "auth": {
          "additionalProperties": true,
          "properties": {
            "existingPasswordSecret": {
              "default": "labs64io-shared-secret",
              "title": "existingPasswordSecret",
              "type": "string"
            },
            "existingSecretPasswordKey": {
              "default": "SPRING_RABBITMQ_PASSWORD",
              "title": "existingSecretPasswordKey",
              "type": "string"
            },
            "username": {
              "default": "labs64",
              "title": "username",
              "type": "string"
            }
          },
          "required": [
            "username",
            "existingPasswordSecret",
            "existingSecretPasswordKey"
          ],
          "title": "auth",
          "type": "object"
        },
        "enabled": {
          "default": true,
          "title": "enabled",
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "rabbitmq",
      "type": "object"
    },
    "redis": {
      "additionalProperties": true,
      "properties": {
        "architecture": {
          "default": "standalone",
          "title": "architecture",
          "type": "string"
        },
        "auth": {
          "additionalProperties": true,
          "properties": {
            "existingSecret": {
              "default": "labs64io-shared-secret",
              "title": "existingSecret",
              "type": "string"
            },
            "existingSecretPasswordKey": {
              "default": "SPRING_DATA_REDIS_PASSWORD",
              "title": "existingSecretPasswordKey",
              "type": "string"
            }
          },
          "required": [
            "existingSecret",
            "existingSecretPasswordKey"
          ],
          "title": "auth",
          "type": "object"
        },
        "enabled": {
          "default": true,
          "title": "enabled",
          "type": "boolean"
        }
      },
      "required": [
        "enabled",
        "architecture"
      ],
      "title": "redis",
      "type": "object"
    },
    "secrets": {
      "additionalProperties": false,
      "properties": {
        "postgresqlPassword": {
          "default": "labs64_dev_password",
          "description": "Base64 encoded secrets injected into labs64io-shared-secret.\nOut of the box, we use a default dev password so Bitnami and Java apps sync up.\nChange these in production!",
          "title": "postgresqlPassword",
          "type": "string"
        },
        "rabbitmqPassword": {
          "default": "labs64_dev_password",
          "title": "rabbitmqPassword",
          "type": "string"
        },
        "redisPassword": {
          "default": "labs64_dev_password",
          "title": "redisPassword",
          "type": "string"
        }
      },
      "required": [
        "postgresqlPassword",
        "rabbitmqPassword",
        "redisPassword"
      ],
      "title": "secrets",
      "type": "object"
    }
  },
  "required": [
    "secrets"
  ],
  "type": "object"
}
