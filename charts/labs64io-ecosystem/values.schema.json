      ],
      "title": "api-gateway",
      "type": "object"
    },
    "auditflow": {
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "default": true,
          "title": "enabled",
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "auditflow",
      "type": "object"
    },
    "authz-pdp": {
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "default": true,
          "title": "enabled",
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "authz-pdp",
      "type": "object"
    },
    "checkout": {
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "default": true,
          "title": "enabled",
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "checkout",
      "type": "object"
    },
    "customer-portal": {
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "default": true,
          "title": "enabled",
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "customer-portal",
      "type": "object"
    },
    "global": {
      "additionalProperties": true,
      "description": "Global Configuration Shared Across Ecosystem",
      "properties": {
        "postgresql": {
          "additionalProperties": false,
          "description": "External dependencies",
          "properties": {
            "database": {
              "default": "labs64io",
              "title": "database",
              "type": "string"
            },
            "host": {
              "default": "{{ .Release.Name }}-postgresql",
              "title": "host",
              "type": "string"
            },
            "port": {
              "default": 5432,
              "title": "port",
