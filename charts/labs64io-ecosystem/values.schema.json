          "required": [
            "host",
            "port",
            "username",
            "database"
          ],
          "title": "postgresql",
          "type": "object"
        },
        "rabbitmq": {
          "additionalProperties": false,
          "properties": {
            "host": {
              "default": "{{ .Release.Name }}-rabbitmq",
              "title": "host",
              "type": "string"
            },
            "port": {
              "default": 5672,
              "title": "port",
              "type": "integer"
            },
            "username": {
              "default": "labs64",
