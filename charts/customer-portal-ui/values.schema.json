{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "affinity": {
      "additionalProperties": false,
      "required": [],
      "title": "affinity",
      "type": "object"
    },
    "application": {
      "additionalProperties": false,
      "properties": {
        "runtimeEnv": {
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "default": true,
              "description": "Enable loading a runtime config file (env.json).",
              "title": "enabled",
              "type": "boolean"
            },
            "env": {
              "additionalProperties": false,
              "description": "Key-value pairs written into env.json.",
              "properties": {
                "VITE_API_URL": {
                  "default": "https://\u003cHOST\u003e/api/v1/customer-portal",
                  "description": "Primary API base URL — replace \u003cHOST\u003e with your domain/host.",
                  "title": "VITE_API_URL",
                  "type": "string"
                }
              },
              "required": [
                "VITE_API_URL"
              ],
              "title": "env",
              "type": "object"
            },
            "path": {
              "default": "/usr/share/nginx/html/config/env.json",
              "description": "Absolute path in the container where env.json is mounted and served from.",
              "title": "path",
              "type": "string"
            },
            "strict": {
              "default": true,
              "description": "Strict mode: if true, the container must not start when env.json is missing/invalid.",
              "title": "strict",
              "type": "boolean"
            }
          },
          "required": [
            "enabled",
            "strict",
            "path",
            "env"
          ],
          "title": "runtimeEnv",
          "type": "object"
        }
      },
      "required": [
        "runtimeEnv"
      ],
      "title": "application",
      "type": "object"
    },
    "autoscaling": {
      "additionalProperties": false,
      "description": "This section is for setting up autoscaling",
      "properties": {
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "maxReplicas": {
          "default": 3,
          "title": "maxReplicas",
          "type": "integer"
        },
        "minReplicas": {
          "default": 1,
          "title": "minReplicas",
          "type": "integer"
        },
        "targetCPUUtilizationPercentage": {
          "default": 80,
          "title": "targetCPUUtilizationPercentage",
          "type": "integer"
        }
      },
      "required": [
        "enabled",
        "minReplicas",
        "maxReplicas",
        "targetCPUUtilizationPercentage"
      ],
      "title": "autoscaling",
      "type": "object"
    },
    "chart-libs": {
      "additionalProperties": true,
      "description": "Values passed to the chart-libs library dependency (present so the generated schema accepts the key Helm injects for the dependency)",
      "required": [],
      "title": "chart-libs",
      "type": "object"
    },
    "env": {
      "items": {
        "required": []
      },
      "title": "env",
      "type": "array"
    },
    "fullnameOverride": {
      "default": "",
      "title": "fullnameOverride",
      "type": "string"
    },
    "gateway": {
      "additionalProperties": false,
      "description": "Gateway routes published by this module (rendered by chart-libs.gateway-routes)",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Publish this module's routes on the Traefik gateway",
          "title": "enabled",
          "type": "boolean"
        },
        "entryPoints": {
          "description": "Traefik entry points",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ],
            "required": []
          },
          "title": "entryPoints",
          "type": "array"
        },
        "prefix": {
          "default": "/customer-portal",
          "description": "External path prefix; customer-portal-ui serves under /customer-portal",
          "title": "prefix",
          "type": "string"
        },
        "routes": {
          "description": "Routes exposed by this module",
          "items": {
            "anyOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "path": {
                    "default": "",
                    "title": "path",
                    "type": "string"
                  },
                  "port": {
                    "default": 8080,
                    "title": "port",
                    "type": "integer"
                  },
                  "roles": {
                    "items": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "string"
                        }
                      ],
                      "required": []
                    },
                    "title": "roles",
                    "type": "array"
                  }
                },
                "required": [
                  "path",
                  "port",
                  "roles"
                ],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "routes",
          "type": "array"
        },
        "sharedMiddlewares": {
          "additionalProperties": false,
          "description": "Names of the shared middlewares provided by the gateway-common chart",
          "properties": {
            "auth": {
              "default": "gateway-common-auth",
              "title": "auth",
              "type": "string"
            },
            "compress": {
              "default": "gateway-common-compress",
              "title": "compress",
              "type": "string"
            },
            "rateLimit": {
              "default": "gateway-common-ratelimit",
              "title": "rateLimit",
              "type": "string"
            },
            "securityHeaders": {
              "default": "gateway-common-security-headers",
              "title": "securityHeaders",
              "type": "string"
            }
          },
          "required": [
            "auth",
            "rateLimit",
            "securityHeaders",
            "compress"
          ],
          "title": "sharedMiddlewares",
          "type": "object"
        }
      },
      "required": [
        "enabled",
        "prefix",
        "entryPoints",
        "sharedMiddlewares",
        "routes"
      ],
      "title": "gateway",
      "type": "object"
    },
    "global": {
      "description": "Global values are values that can be accessed from any chart or subchart by exactly the same name.",
      "required": [],
      "title": "global",
      "type": "object"
    },
    "image": {
      "additionalProperties": false,
      "description": "This sets the container image more information can be found here: https://kubernetes.io/docs/concepts/containers/images/",
      "properties": {
        "pullPolicy": {
          "default": "IfNotPresent",
          "description": "This sets the pull policy for images.",
          "title": "pullPolicy",
          "type": "string"
        },
        "repository": {
          "default": "labs64/customer-portal-ui",
          "title": "repository",
          "type": "string"
        },
        "tag": {
          "default": "",
          "description": "Overrides the image tag whose default is the chart appVersion.",
          "title": "tag",
          "type": "string"
        }
      },
      "required": [
        "repository",
        "pullPolicy",
        "tag"
      ],
      "title": "image",
      "type": "object"
    },
    "imagePullSecrets": {
      "description": "This is for the secrets for pulling an image from a private repository more information can be found here: https://kubernetes.io/docs/tasks/configure-pod-container/pull-image-private-registry/",
      "items": {
        "required": []
      },
      "title": "imagePullSecrets",
      "type": "array"
    },
    "ingress": {
      "additionalProperties": false,
      "description": "This block is for setting up the ingress for more information can be found here: https://kubernetes.io/docs/concepts/services-networking/ingress/",
      "properties": {
        "annotations": {
          "additionalProperties": false,
          "required": [],
          "title": "annotations",
          "type": "object"
        },
        "className": {
          "default": "nginx",
          "title": "className",
          "type": "string"
        },
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "hosts": {
          "items": {
            "anyOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "host": {
                    "default": "localhost",
                    "title": "host",
                    "type": "string"
                  },
                  "paths": {
                    "items": {
                      "anyOf": [
                        {
                          "additionalProperties": false,
                          "properties": {
                            "path": {
                              "default": "/",
                              "title": "path",
                              "type": "string"
                            },
                            "pathType": {
                              "default": "Prefix",
                              "title": "pathType",
                              "type": "string"
                            }
                          },
                          "required": [
                            "path",
                            "pathType"
                          ],
                          "type": "object"
                        }
                      ],
                      "required": []
                    },
                    "title": "paths",
                    "type": "array"
                  }
                },
                "required": [
                  "host",
                  "paths"
                ],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "hosts",
          "type": "array"
        },
        "tls": {
          "items": {
            "required": []
          },
          "title": "tls",
          "type": "array"
        }
      },
      "required": [
        "enabled",
        "className",
        "annotations",
        "hosts",
        "tls"
      ],
      "title": "ingress",
      "type": "object"
    },
    "ingressroute": {
      "additionalProperties": false,
      "description": "IngressRoute configuration for Traefik more information can be found here: https://doc.traefik.io/traefik/routing/providers/kubernetes-crd/",
      "properties": {
        "enabled": {
          "default": false,
          "description": "This sets whether the IngressRoute is enabled or not",
          "title": "enabled",
          "type": "boolean"
        },
        "entryPoints": {
          "description": "Entry points for the IngressRoute",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "string"
              }
            ],
            "required": []
          },
          "title": "entryPoints",
          "type": "array"
        },
        "host": {
          "default": "localhost",
          "description": "Host for the IngressRoute",
          "title": "host",
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "host",
        "entryPoints"
      ],
      "title": "ingressroute",
      "type": "object"
    },
    "lifecycle": {
      "additionalProperties": false,
      "properties": {
        "preStopDrainSeconds": {
          "default": 5,
          "description": "preStop sleep (seconds) so the gateway deregisters the pod before shutdown; 0 disables",
          "title": "preStopDrainSeconds",
          "type": "integer"
        }
      },
      "required": [
        "preStopDrainSeconds"
      ],
      "title": "lifecycle",
      "type": "object"
    },
    "livenessProbe": {
      "additionalProperties": false,
      "description": "This is to setup the liveness probes",
      "properties": {
        "failureThreshold": {
          "default": 3,
          "title": "failureThreshold",
          "type": "integer"
        },
        "httpGet": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "default": "/",
              "title": "path",
              "type": "string"
            },
            "port": {
              "default": 8080,
              "title": "port",
              "type": "integer"
            }
          },
          "required": [
            "path",
            "port"
          ],
          "title": "httpGet",
          "type": "object"
        },
        "initialDelaySeconds": {
          "default": 10,
          "title": "initialDelaySeconds",
          "type": "integer"
        },
        "periodSeconds": {
          "default": 10,
          "title": "periodSeconds",
          "type": "integer"
        },
        "timeoutSeconds": {
          "default": 2,
          "title": "timeoutSeconds",
          "type": "integer"
        }
      },
      "required": [
        "httpGet",
        "initialDelaySeconds",
        "periodSeconds",
        "failureThreshold",
        "timeoutSeconds"
      ],
      "title": "livenessProbe",
      "type": "object"
    },
    "nameOverride": {
      "default": "",
      "description": "This is to override the chart name.",
      "title": "nameOverride",
      "type": "string"
    },
    "networkPolicy": {
      "additionalProperties": false,
      "description": "NetworkPolicy: allow ingress from Traefik and same-namespace pods only (rendered by chart-libs.networkpolicy)",
      "properties": {
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "extraIngress": {
          "description": "Additional raw ingress rules",
          "items": {
            "required": []
          },
          "title": "extraIngress",
          "type": "array"
        },
        "gatewayNamespace": {
          "default": "tools",
          "description": "Namespace where Traefik runs",
          "title": "gatewayNamespace",
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "gatewayNamespace",
        "extraIngress"
      ],
      "title": "networkPolicy",
      "type": "object"
    },
    "nodeSelector": {
      "additionalProperties": false,
      "required": [],
      "title": "nodeSelector",
      "type": "object"
    },
    "podAnnotations": {
      "additionalProperties": false,
      "description": "This is for setting Kubernetes Annotations to a Pod.",
      "required": [],
      "title": "podAnnotations",
      "type": "object"
    },
