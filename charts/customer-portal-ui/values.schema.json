    "podSecurityContext": {
      "additionalProperties": false,
      "description": "Non-root pod security context. The image is nginx-unprivileged (UID 101), so the\nwhole pod runs unprivileged and listens on 8080.",
      "properties": {
        "fsGroup": {
          "default": 101,
          "title": "fsGroup",
          "type": "integer"
        },
        "runAsGroup": {
          "default": 101,
          "title": "runAsGroup",
          "type": "integer"
        },
        "runAsNonRoot": {
          "default": true,
          "title": "runAsNonRoot",
          "type": "boolean"
        },
        "runAsUser": {
          "default": 101,
          "title": "runAsUser",
          "type": "integer"
