          "required": [
            "path",
            "port"
          ],
          "title": "httpGet",
          "type": "object"
        },
        "initialDelaySeconds": {
          "default": 5,
          "title": "initialDelaySeconds",
          "type": "integer"
        },
        "periodSeconds": {
          "default": 5,
          "title": "periodSeconds",
          "type": "integer"
        },
        "timeoutSeconds": {
          "default": 2,
          "title": "timeoutSeconds",
          "type": "integer"
        }
