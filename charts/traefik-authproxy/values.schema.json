            "required": [
              "name",
              "value"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "name": {
                "default": "ROUTES_DIR",
                "title": "name",
                "type": "string"
              },
              "value": {
                "default": "/app/routes",
                "title": "value",
                "type": "string"
              }
            },
            "required": [
              "name",
              "value"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "name": {
                "default": "STATIC_ROUTES_FILE",
                "title": "name",
                "type": "string"
              },
              "value": {
                "default": "/opt/application-config/static_routes.yaml",
