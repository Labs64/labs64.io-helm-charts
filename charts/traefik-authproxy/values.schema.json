      "type": "object"
    },
    "service": {
      "additionalProperties": false,
      "description": "This is for setting up a service more information can be found here: https://kubernetes.io/docs/concepts/services-networking/service/",
      "properties": {
        "port": {
          "default": 8081,
          "description": "This sets the ports more information can be found here: https://kubernetes.io/docs/concepts/services-networking/service/#field-spec-ports",
          "title": "port",
          "type": "integer"
        },
        "type": {
          "default": "ClusterIP",
          "description": "This sets the service type more information can be found here: https://kubernetes.io/docs/concepts/services-networking/service/#publishing-services-service-types",
          "title": "type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "port"
      ],
      "title": "service",
      "type": "object"
    },
    "serviceAccount": {
      "additionalProperties": false,
      "description": "This section builds out the service account more information can be found here: https://kubernetes.io/docs/concepts/security/service-accounts/",
      "properties": {
        "annotations": {
          "additionalProperties": false,
          "description": "Annotations to add to the service account",
          "required": [],
          "title": "annotations",
          "type": "object"
        },
        "automount": {
          "default": true,
          "description": "Automatically mount a ServiceAccount's API credentials?",
          "title": "automount",
          "type": "boolean"
        },
        "create": {
          "default": true,
          "description": "Specifies whether a service account should be created",
          "title": "create",
          "type": "boolean"
        },
        "name": {
          "default": "",
          "description": "The name of the service account to use.\nIf not set and create is true, a name is generated using the fullname template",
          "title": "name",
          "type": "string"
        }
      },
      "required": [
        "create",
        "automount",
        "annotations",
        "name"
      ],
      "title": "serviceAccount",
      "type": "object"
    },
    "startupProbe": {
      "additionalProperties": false,
      "description": "Startup probe (rendered by chart-libs.startupProbe): guards cold start so the\nliveness probe never kills a still-booting pod. Max boot budget = failureThreshold * periodSeconds.",
      "properties": {
        "failureThreshold": {
          "default": 20,
          "title": "failureThreshold",
          "type": "integer"
        },
        "httpGet": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "default": "/health/ready",
              "title": "path",
              "type": "string"
            },
            "port": {
              "default": 8081,
              "title": "port",
              "type": "integer"
            }
          },
          "required": [
            "path",
            "port"
          ],
          "title": "httpGet",
          "type": "object"
        },
        "periodSeconds": {
          "default": 3,
          "title": "periodSeconds",
          "type": "integer"
        },
        "timeoutSeconds": {
          "default": 2,
          "title": "timeoutSeconds",
          "type": "integer"
        }
      },
      "required": [
        "httpGet",
        "failureThreshold",
        "periodSeconds",
        "timeoutSeconds"
      ],
      "title": "startupProbe",
      "type": "object"
    },
    "staticPolicies": {
      "description": "Static prefix policies for gateway surfaces without an OpenAPI spec\n(UI bundles). Rendered into static_routes.yaml; `id` MUST match an action in\nthe Cerbos static_api policy (charts/cerbos/policies/static_api.yaml) — that\npolicy makes the decision, this only carries the routing prefix. Longest prefix\nwins; consulted only when no module route matches.\nTODO: remove after the corresponding modules will be using OpenAPI",
      "items": {
        "anyOf": [
          {
            "additionalProperties": false,
            "properties": {
              "id": {
                "default": "checkout-ui",
                "title": "id",
                "type": "string"
              },
              "prefix": {
                "default": "/checkout-ui",
                "title": "prefix",
                "type": "string"
              },
              "public": {
                "default": false,
                "title": "public",
                "type": "boolean"
              },
              "scopes": {
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "string"
                    }
                  ],
                  "required": []
                },
                "title": "scopes",
                "type": "array"
              }
            },
            "required": [
              "id",
              "prefix",
              "public",
              "scopes"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "id": {
                "default": "customer-portal-ui",
                "title": "id",
                "type": "string"
              },
              "prefix": {
                "default": "/customer-portal-ui",
                "title": "prefix",
                "type": "string"
              },
              "public": {
                "default": false,
                "title": "public",
                "type": "boolean"
              },
              "scopes": {
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "string"
                    }
                  ],
                  "required": []
                },
                "title": "scopes",
                "type": "array"
              }
            },
            "required": [
              "id",
              "prefix",
              "public",
              "scopes"
            ],
            "type": "object"
          }
        ],
        "required": []
      },
      "title": "staticPolicies",
      "type": "array"
    },
    "terminationGracePeriodSeconds": {
      "default": 45,
      "description": "Graceful shutdown: drain on rolling updates / scale-in (uvicorn handles SIGTERM;\npreStop gives Traefik/kube-proxy time to deregister the pod first).",
      "title": "terminationGracePeriodSeconds",
      "type": "integer"
    },
    "tolerations": {
      "items": {
        "required": []
      },
      "title": "tolerations",
      "type": "array"
    },
    "volumeMounts": {
      "description": "Additional volumeMounts on the output Deployment definition.",
      "items": {
        "required": []
      },
      "title": "volumeMounts",
      "type": "array"
    },
    "volumes": {
      "description": "Additional volumes on the output Deployment definition.",
      "items": {
        "required": []
      },
      "title": "volumes",
      "type": "array"
    }
  },
  "required": [
    "replicaCount",
    "image",
    "imagePullSecrets",
    "nameOverride",
