                "type": "string"
              },
              "value": {
                "default": "http://keycloak.tools.svc.cluster.local/realms/labs64io/.well-known/openid-configuration",
                "title": "value",
                "type": "string"
              }
            },
            "required": [
              "name",
              "value"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "name": {
                "default": "OIDC_AUDIENCE",
                "title": "name",
                "type": "string"
              },
              "value": {
                "default": "account",
                "title": "value",
                "type": "string"
              }
            },
            "required": [
              "name",
              "value"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "name": {
                "default": "LOG_LEVEL",
                "title": "name",
                "type": "string"
              },
              "value": {
                "default": "INFO",
                "title": "value",
                "type": "string"
              }
            },
            "required": [
              "name",
              "value"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "name": {
                "default": "TOKEN_SCOPES_CLAIM_PATHS",
                "title": "name",
                "type": "string"
              },
              "value": {
                "default": "scope,realm_access.roles,resource_access.{audience}.roles",
                "title": "value",
                "type": "string"
              }
            },
            "required": [
              "name",
              "value"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "name": {
                "default": "TOKEN_TENANT_CLAIM_PATH",
                "title": "name",
                "type": "string"
              },
              "value": {
                "default": "tenant",
                "title": "value",
                "type": "string"
              }
            },
            "required": [
              "name",
              "value"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "name": {
                "default": "CERBOS_URL",
                "title": "name",
