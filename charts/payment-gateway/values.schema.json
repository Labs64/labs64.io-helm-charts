{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "affinity": {
      "additionalProperties": false,
      "required": [],
      "title": "affinity",
      "type": "object"
    },
    "applicationType": {
      "default": "java",
      "title": "applicationType",
      "type": "string"
    },
    "applicationYaml": {
      "additionalProperties": false,
      "description": "Additional application properties",
      "properties": {
        "spring": {
          "additionalProperties": false,
          "description": "Spring configuration",
          "required": [],
          "title": "spring",
          "type": "object"
        }
      },
      "required": [
        "spring"
      ],
      "title": "applicationYaml",
      "type": "object"
    },
    "autoscaling": {
      "additionalProperties": false,
      "description": "This section is for setting up autoscaling more information can be found here: https://kubernetes.io/docs/concepts/workloads/autoscaling/",
      "properties": {
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "maxReplicas": {
          "default": 3,
          "title": "maxReplicas",
          "type": "integer"
        },
        "minReplicas": {
          "default": 1,
          "title": "minReplicas",
          "type": "integer"
        },
        "targetCPUUtilizationPercentage": {
          "default": 80,
          "title": "targetCPUUtilizationPercentage",
          "type": "integer"
        }
      },
      "required": [
        "enabled",
        "minReplicas",
        "maxReplicas",
        "targetCPUUtilizationPercentage"
      ],
      "title": "autoscaling",
      "type": "object"
    },
    "chart-libs": {
      "additionalProperties": true,
      "description": "Values passed to the chart-libs library dependency (present so the generated schema accepts the key Helm injects for the dependency)",
      "required": [],
      "title": "chart-libs",
      "type": "object"
    },
    "enabled": {
      "default": true,
      "title": "enabled",
      "type": "boolean"
    },
    "env": {
      "items": {
        "required": []
      },
      "title": "env",
      "type": "array"
    },
    "externalSecrets": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "storeName": {
          "default": "local-kubernetes-store",
          "title": "storeName",
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "storeName"
      ],
      "title": "externalSecrets",
      "type": "object"
    },
    "fullnameOverride": {
      "default": "",
      "title": "fullnameOverride",
      "type": "string"
    },
    "gateway": {
      "additionalProperties": false,
      "description": "Gateway routes published by this module (rendered by chart-libs.gateway-routes)",
      "properties": {
        "authPolicy": {
          "additionalProperties": false,
          "description": "Auth-policy publication. NOTE: the traefik-authproxy no longer\nlive-discovers per-module policies via /.well-known/auth-policy — it loads a\ngenerated routes manifest (charts/api-gateway/routes/) and asks the\ncentral Cerbos PDP for every decision. This block is retained for backward\ncompatibility and is a no-op for edge enforcement.",
          "properties": {
            "basePath": {
              "default": "",
              "description": "External base path prepended to the module's OpenAPI paths; defaults to \u003cprefix\u003e/api/v1",
              "title": "basePath",
              "type": "string"
            },
            "enabled": {
              "default": true,
              "description": "Publish this module's auth policy to the gateway ACS",
              "title": "enabled",
              "type": "boolean"
            }
          },
          "required": [
            "enabled",
            "basePath"
          ],
          "title": "authPolicy",
          "type": "object"
        },
        "enabled": {
          "default": false,
          "description": "Publish this module's routes on the Traefik gateway",
          "title": "enabled",
          "type": "boolean"
        },
        "parentRefs": {
          "description": "Gateway API parent Gateway(s) this module's HTTPRoute attaches to",
          "items": {
            "anyOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "default": "labs64io-gateway",
                    "title": "name",
                    "type": "string"
                  },
                  "namespace": {
                    "default": "tools",
                    "title": "namespace",
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "namespace"
                ],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "parentRefs",
          "type": "array"
        },
        "prefix": {
          "default": "",
          "description": "External path prefix; defaults to /\u003cchart-name\u003e",
          "title": "prefix",
          "type": "string"
        },
        "routes": {
          "description": "Routes exposed by this module.\nThe whole API surface is ONE route through ForwardAuth: the authproxy is the\nPEP and derives public-vs-protected per operation from OpenAPI x-labs64-auth\n(generated into the authproxy routes manifest + the central Cerbos PDP). Public\noperations (payment-definitions, PSP webhooks, provider/checkout redirect returns\n— none can carry a JWT) are allowed without a token by the authproxy itself, so\nthey MUST NOT be re-declared here. Re-declaring them as edge routes duplicates\nthe OpenAPI PEP and mis-strips their paths. OpenAPI stays the single source of truth.",
          "items": {
            "anyOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "path": {
                    "default": "/api/v1",
                    "title": "path",
                    "type": "string"
                  },
                  "port": {
                    "default": 8080,
                    "title": "port",
                    "type": "integer"
                  },
                  "stripPath": {
                    "default": true,
                    "title": "stripPath",
                    "type": "boolean"
                  }
                },
                "required": [
                  "path",
                  "port",
                  "stripPath"
                ],
                "type": "object"
              },
              {
                "additionalProperties": false,
                "properties": {
                  "path": {
                    "default": "/v3/api-docs",
                    "title": "path",
                    "type": "string"
                  },
                  "port": {
                    "default": 8080,
                    "title": "port",
                    "type": "integer"
                  },
                  "public": {
                    "default": true,
                    "title": "public",
                    "type": "boolean"
                  },
                  "stripPrefix": {
                    "default": true,
                    "title": "stripPrefix",
                    "type": "boolean"
                  }
                },
                "required": [
                  "path",
                  "port",
                  "public",
                  "stripPrefix"
                ],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "routes",
          "type": "array"
        },
        "sharedMiddlewares": {
          "additionalProperties": false,
          "description": "Names of the shared middlewares provided by the api-gateway chart (fullnameOverride: gateway-common)",
          "properties": {
            "auth": {
              "default": "gateway-common-auth",
              "title": "auth",
              "type": "string"
            },
            "compress": {
              "default": "gateway-common-compress",
              "title": "compress",
              "type": "string"
            },
            "rateLimit": {
              "default": "gateway-common-ratelimit",
              "title": "rateLimit",
              "type": "string"
            }
          },
          "required": [
            "auth",
            "rateLimit",
            "compress"
          ],
          "title": "sharedMiddlewares",
          "type": "object"
        }
      },
      "required": [
        "enabled",
        "prefix",
        "parentRefs",
        "sharedMiddlewares",
        "authPolicy",
        "routes"
      ],
      "title": "gateway",
      "type": "object"
    },
    "global": {
      "additionalProperties": true,
      "description": "Global values shared across Labs64.IO charts and Bitnami subcharts",
      "properties": {
        "security": {
          "additionalProperties": false,
          "properties": {
            "allowInsecureImages": {
              "default": true,
              "description": "Required by Bitnami subcharts when images are pulled from bitnamilegacy (image substitution guard)",
              "title": "allowInsecureImages",
              "type": "boolean"
            }
          },
          "required": [
            "allowInsecureImages"
          ],
          "title": "security",
          "type": "object"
        }
      },
      "required": [
        "security"
      ],
      "title": "global",
      "type": "object"
    },
    "gracefulShutdown": {
      "additionalProperties": false,
      "properties": {
        "timeout": {
          "default": "30s",
          "description": "Max time Spring Boot waits for in-flight requests before forced shutdown",
          "title": "timeout",
          "type": "string"
        }
      },
      "required": [
        "timeout"
      ],
      "title": "gracefulShutdown",
      "type": "object"
    },
    "image": {
      "additionalProperties": false,
      "description": "This sets the container image more information can be found here: https://kubernetes.io/docs/concepts/containers/images/",
      "properties": {
        "pullPolicy": {
          "default": "IfNotPresent",
          "description": "This sets the pull policy for images.",
          "title": "pullPolicy",
          "type": "string"
        },
        "repository": {
          "default": "labs64/payment-gateway",
          "title": "repository",
          "type": "string"
        },
        "tag": {
          "default": "",
          "description": "Overrides the image tag whose default is the chart appVersion.",
          "title": "tag",
          "type": "string"
        }
      },
      "required": [
        "repository",
        "pullPolicy",
        "tag"
      ],
      "title": "image",
      "type": "object"
    },
    "imagePullSecrets": {
      "description": "This is for the secrets for pulling an image from a private repository more information can be found here: https://kubernetes.io/docs/tasks/configure-pod-container/pull-image-private-registry/",
      "items": {
        "required": []
      },
      "title": "imagePullSecrets",
      "type": "array"
    },
    "lifecycle": {
      "additionalProperties": false,
      "properties": {
        "preStopDrainSeconds": {
          "default": 5,
          "description": "preStop sleep (seconds) so Traefik/kube-proxy deregister the pod before shutdown; 0 disables",
          "title": "preStopDrainSeconds",
          "type": "integer"
        }
      },
      "required": [
        "preStopDrainSeconds"
      ],
      "title": "lifecycle",
      "type": "object"
    },
    "livenessProbe": {
      "additionalProperties": false,
      "description": "This is to setup the liveness probes more information can be found here: https://kubernetes.io/docs/tasks/configure-pod-container/configure-liveness-readiness-startup-probes/",
      "properties": {
        "failureThreshold": {
          "default": 3,
          "title": "failureThreshold",
          "type": "integer"
        },
        "httpGet": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "default": "/actuator/health/liveness",
              "title": "path",
              "type": "string"
            },
            "port": {
              "default": 8080,
              "title": "port",
              "type": "integer"
            }
          },
          "required": [
            "path",
            "port"
          ],
          "title": "httpGet",
          "type": "object"
        },
        "initialDelaySeconds": {
          "default": 30,
          "title": "initialDelaySeconds",
          "type": "integer"
        },
        "periodSeconds": {
          "default": 10,
          "title": "periodSeconds",
          "type": "integer"
        },
        "timeoutSeconds": {
          "default": 2,
          "title": "timeoutSeconds",
          "type": "integer"
        }
      },
      "required": [
        "httpGet",
        "initialDelaySeconds",
        "periodSeconds",
        "failureThreshold",
        "timeoutSeconds"
      ],
      "title": "livenessProbe",
      "type": "object"
    },
    "nameOverride": {
      "default": "",
      "description": "This is to override the chart name.",
      "title": "nameOverride",
      "type": "string"
    },
    "networkPolicy": {
      "additionalProperties": false,
      "description": "NetworkPolicy: allow ingress from Traefik and same-namespace pods only (rendered by chart-libs.networkpolicy)",
      "properties": {
        "egress": {
          "description": "Egress rules enforcing database-per-service isolation.",
          "items": {
            "anyOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "ports": {
                    "items": {
                      "anyOf": [
                        {
                          "additionalProperties": false,
                          "properties": {
                            "port": {
                              "default": 3593,
                              "title": "port",
                              "type": "integer"
                            },
                            "protocol": {
                              "default": "TCP",
                              "title": "protocol",
                              "type": "string"
                            }
                          },
                          "required": [
                            "protocol",
                            "port"
                          ],
                          "type": "object"
                        }
                      ],
                      "required": []
                    },
                    "title": "ports",
                    "type": "array"
                  },
                  "to": {
                    "items": {
                      "anyOf": [
                        {
                          "additionalProperties": false,
                          "properties": {
                            "podSelector": {
                              "additionalProperties": false,
                              "properties": {
                                "matchLabels": {
                                  "additionalProperties": false,
                                  "properties": {
                                    "app.kubernetes.io/name": {
                                      "default": "authz-pdp",
                                      "title": "app.kubernetes.io/name",
                                      "type": "string"
                                    }
                                  },
                                  "required": [
                                    "app.kubernetes.io/name"
                                  ],
                                  "title": "matchLabels",
                                  "type": "object"
                                }
                              },
                              "required": [
                                "matchLabels"
                              ],
                              "title": "podSelector",
                              "type": "object"
                            }
                          },
                          "required": [
                            "podSelector"
                          ],
                          "type": "object"
                        }
                      ],
                      "required": []
                    },
                    "title": "to",
                    "type": "array"
                  }
                },
                "required": [
                  "to",
                  "ports"
                ],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "egress",
          "type": "array"
        },
        "enabled": {
          "default": false,
          "title": "enabled",
          "type": "boolean"
        },
        "extraIngress": {
          "description": "Additional raw ingress rules",
          "items": {
            "required": []
          },
          "title": "extraIngress",
          "type": "array"
        },
        "gatewayNamespace": {
          "default": "tools",
          "description": "Namespace where Traefik runs",
          "title": "gatewayNamespace",
          "type": "string"
        },
        "toolsEgress": {
          "description": "Tools-namespace destinations this service needs (name + port pairs); rendered as\nscoped egress rules — NOT a blanket allow to the whole tools namespace — to preserve\ndatabase-per-service isolation.",
          "items": {
            "anyOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "default": "rabbitmq",
                    "title": "name",
                    "type": "string"
                  },
                  "port": {
                    "default": 5672,
                    "title": "port",
                    "type": "integer"
                  }
                },
                "required": [
                  "name",
                  "port"
                ],
                "type": "object"
              },
              {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "default": "postgresql",
                    "title": "name",
                    "type": "string"
                  },
                  "port": {
                    "default": 5432,
                    "title": "port",
                    "type": "integer"
                  }
                },
                "required": [
                  "name",
                  "port"
                ],
                "type": "object"
              },
              {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "default": "redis",
                    "title": "name",
                    "type": "string"
                  },
                  "port": {
                    "default": 6379,
                    "title": "port",
                    "type": "integer"
                  }
                },
                "required": [
                  "name",
                  "port"
                ],
                "type": "object"
              }
            ],
            "required": []
          },
          "title": "toolsEgress",
          "type": "array"
        }
      },
      "required": [
        "enabled",
        "gatewayNamespace",
        "extraIngress",
        "toolsEgress",
        "egress"
      ],
      "title": "networkPolicy",
      "type": "object"
    },
    "nodeSelector": {
      "additionalProperties": false,
      "required": [],
      "title": "nodeSelector",
      "type": "object"
    },
    "observability": {
      "additionalProperties": false,
      "description": "Observability is infrastructure-owned: the same image runs with or without it.\nWhen enabled, the bundled OTel Java Agent is activated via JAVA_TOOL_OPTIONS and\nPrometheus scrape annotations (Micrometer /actuator/prometheus) are added.",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Enable runtime instrumentation (traces + logs via OTLP; metrics via Prometheus scrape)",
          "title": "enabled",
          "type": "boolean"
        },
        "metricsPath": {
          "default": "/actuator/prometheus",
          "description": "Prometheus metrics path scraped from the pod",
          "title": "metricsPath",
          "type": "string"
        },
        "otlpEndpoint": {
          "default": "http://$(NODE_IP):4318",
          "description": "OTLP endpoint of the OpenTelemetry Collector",
          "title": "otlpEndpoint",
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "otlpEndpoint",
        "metricsPath"
      ],
      "title": "observability",
      "type": "object"
    },
