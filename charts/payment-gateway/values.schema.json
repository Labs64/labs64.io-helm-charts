    "secrets": {
      "additionalProperties": false,
      "description": "Secret data to be used as environment variables (delivered via envFrom).\nExternal installs supply broker/database/cache credentials here, e.g.\n  SPRING_RABBITMQ_USERNAME / SPRING_RABBITMQ_PASSWORD, SPRING_DATASOURCE_USERNAME / SPRING_DATASOURCE_PASSWORD, SPRING_DATA_REDIS_PASSWORD.\nWhen rabbitmq.enabled=true / postgresql.enabled=true / redis.enabled=true the chart adds these keys automatically from rabbitmq.auth / postgresql.auth / redis.auth.\nKeys you set here take precedence over the bundled-dep keys. On helm upgrade the Secret is deleted and recreated (hook-managed).\nNote: the Secret is hook-managed (pre-install) and survives helm uninstall.",
      "properties": {
        "data": {
          "additionalProperties": true,
          "required": [],
          "type": "object"
        }
      },
      "required": [],
      "title": "secrets",
      "type": "object"
    },
