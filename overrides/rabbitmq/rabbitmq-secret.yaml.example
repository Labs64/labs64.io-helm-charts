# RabbitMQ broker credentials — TEMPLATE, for the standalone `install-tool-rabbitmq`
# recipe only (official `rabbitmq:4-management` image; bypasses helmfile and the
# bitnami/rabbitmq chart used by `just install-tools`/`just up`).
#
# Copy this file to `rabbitmq-secret.yaml` (gitignored) and set a real password for
# any shared/non-local environment. Not auto-copied by `just generate-secrets`
# (which only handles the `values.secrets.<env>.yaml.example` convention) — copy it
# by hand before running `just install-tool-rabbitmq` standalone.
#
# For the actual Helmfile-managed RabbitMQ release, see
# `values.secrets.local.yaml.example` in this same directory instead.
#
# This password MUST match `SPRING_RABBITMQ_PASSWORD` in every app module's
# `overrides/<module>/values.secrets.local.yaml` (auditflow, checkout, payment-gateway).
#
# `labs64pw` is a throwaway LOCAL-DEV default only — never reuse it anywhere real.
apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-secret
type: Opaque
stringData:
  RABBITMQ_DEFAULT_USER: "labs64"
  RABBITMQ_DEFAULT_PASS: "labs64pw"
