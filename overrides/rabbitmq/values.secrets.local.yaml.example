# RabbitMQ broker credentials — TEMPLATE.
#
# Copy this file to `values.secrets.local.yaml` (which is gitignored via the
# `values.secrets.*.yaml` rule) and set a real password for any shared/non-local
# environment. `just generate-secrets` (run automatically by `just up`) auto-copies
# this template on first run if no `values.secrets.local.yaml` exists yet.
#
# These are Helm values for the `bitnami/rabbitmq` chart (the Helmfile-managed
# release every app module actually connects to — see helmfile.yaml.gotmpl).
# NOT to be confused with `rabbitmq-secret.yaml(.example)` in this same directory,
# which is a raw Kubernetes Secret consumed only by the standalone, helmfile-bypassing
# `install-tool-rabbitmq` recipe (official `rabbitmq:4-management` image).
#
# This password MUST match `SPRING_RABBITMQ_PASSWORD` in every app module's
# `overrides/<module>/values.secrets.local.yaml` (auditflow, checkout, payment-gateway).
#
# `labs64pw` is a throwaway LOCAL-DEV default only — never reuse it anywhere real.
auth:
  username: "labs64"
  password: "labs64pw"
